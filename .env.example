# Lead Scoring POC — Environment Configuration
# Copy to .env and adjust values as needed.

# Synthetic Data generation
NUM_ACCOUNTS=200
NUM_LEADS=600
NUM_CONTACTS=400
NUM_CAMPAIGN_MEMBERS=4000
DATA_DIR=./data/raw

# Scoring model
ENGAGEMENT_WEIGHT=0.40
PROFILE_WEIGHT=0.25
ACCOUNT_WEIGHT=0.20
MOMENTUM_WEIGHT=0.15
HALF_LIFE_DAYS=45.0

# Tier thresholds
HOT_THRESHOLD=70.0
WARM_THRESHOLD=45.0
NURTURE_THRESHOLD=20.0

# Application
APP_PORT=8501
LOG_LEVEL=INFO
